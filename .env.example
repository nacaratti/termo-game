# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o .env — ele está no .gitignore por motivo.
# ============================================================

# Frontend (Vite expõe para o navegador)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui
# URL pública do site (sem barra final) — usada nas meta tags Open Graph
VITE_PUBLIC_URL=https://seudominio.com
# Google Analytics 4 Measurement ID (ex: G-XXXXXXXXXX) — deixar em branco para desativar
VITE_GA_ID=

# Backend / Agentes (NUNCA expor ao navegador)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Telegram Bot (opcional — só necessário para o CEO Agent enviar relatórios)
TELEGRAM_BOT_TOKEN=123456789:AAAAaaaa-Bbbbb-Cccc-Dddd-Eeeeffff
TELEGRAM_CHAT_ID=000000000

# Dev Agent (opcional — minutos de execução por sessão)
AGENT_DURATION=30
